<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="hibernate.connection.driver_class">
            org.postgresql.Driver
        </property>

        <property name="hibernate.connection.url">
            jdbc:postgresql://localhost:5432/mapping
        </property>

        <property name="hibernate.connection.username">postgres</property>
        <property name="hibernate.connection.password">root</property>

        <property name="hibernate.dialect">
            org.hibernate.dialect.PostgreSQLDialect
        </property>

        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="hibernate.show_sql">true</property>

        <mapping class="com.pushan.OneToOne.Unidirectional.Entity.Users"/>
        <mapping class="com.pushan.OneToOne.Unidirectional.Entity.Passport"/>

        <mapping class="com.pushan.OneToOne.Bidirectional.Entity.UsersBI"/>
        <mapping class="com.pushan.OneToOne.Bidirectional.Entity.PassportBI"/>

    </session-factory>
</hibernate-configuration>